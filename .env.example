# Fantasy Foundry — Environment Variables
# Copy to .env and adjust values as needed.

# Application environment: "development" | "production" (default: development)
FF_ENV=development

# --- Redis ---
# Redis URL for rate limiting, job tracking, and result caching (default: "" = disabled)
FF_REDIS_URL=

# --- Calculator Rate Limits ---
# Sync calculate endpoint rate limit per minute (default: 30)
FF_CALC_SYNC_RATE_LIMIT_PER_MINUTE=30
# Async job creation rate limit per minute (default: 15)
FF_CALC_JOB_CREATE_RATE_LIMIT_PER_MINUTE=15
# Job status polling rate limit per minute (default: 240)
FF_CALC_JOB_STATUS_RATE_LIMIT_PER_MINUTE=240

# --- Projection Rate Limits ---
# Projection query rate limit per minute (default: 120)
FF_PROJ_RATE_LIMIT_PER_MINUTE=120
# Projection export rate limit per minute (default: 30)
FF_EXPORT_RATE_LIMIT_PER_MINUTE=30

# --- Calculator Jobs ---
# Job TTL in seconds (default: 1800)
FF_CALC_JOB_TTL_SECONDS=1800
# Max stored job entries (default: 256)
FF_CALC_JOB_MAX_ENTRIES=256
# Thread pool workers for async jobs (default: 2)
FF_CALC_JOB_WORKERS=2
# Max concurrent active jobs per IP (default: 2)
FF_CALC_MAX_ACTIVE_JOBS_PER_IP=2
# Sync request timeout in seconds (default: 600)
FF_CALC_REQUEST_TIMEOUT_SECONDS=600

# --- Result Cache ---
# Cache TTL in seconds (default: 1800)
FF_CALC_RESULT_CACHE_TTL_SECONDS=1800
# Max cached result entries (default: 256)
FF_CALC_RESULT_CACHE_MAX_ENTRIES=256

# --- Startup ---
# Prewarm default calculator on startup (default: true)
FF_PREWARM_DEFAULT_CALC=true
# Require precomputed dynasty lookup table (default: true)
FF_REQUIRE_PRECOMPUTED_DYNASTY_LOOKUP=true

# --- Networking / Security ---
# Trust X-Forwarded-For header for client IP (default: false)
FF_TRUST_X_FORWARDED_FOR=false
# Comma-separated CIDR ranges for trusted proxies (default: "")
FF_TRUSTED_PROXY_CIDRS=
# Canonical hostname for HSTS/redirect (default: "")
FF_CANONICAL_HOST=
# Comma-separated CORS allow origins (default: "*")
FF_CORS_ALLOW_ORIGINS=*

# --- Calculator Auth ---
# Require API key for calculator endpoints (default: false)
FF_REQUIRE_CALCULATE_AUTH=false
# Comma-separated key:identity pairs (default: "")
FF_CALCULATE_API_KEYS=

# --- Rate Limit Internals ---
# Bucket cleanup sweep interval in seconds (default: 60)
FF_RATE_LIMIT_BUCKET_CLEANUP_INTERVAL_SECONDS=60
